{
  "version": 2,
  "builds": [
    {
      "src": "api/status.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/status", "dest": "/api/status.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
